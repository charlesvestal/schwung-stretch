{
  "title": "Stretch",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Change the tempo and",
        "pitch of a WAV file",
        "independently.",
        "",
        "Uses the Bungee",
        "library for high",
        "quality stretching.",
        "",
        "Set the file's bar",
        "length, target BPM,",
        "and pitch to hear",
        "the result in real",
        "time."
      ]
    },
    {
      "title": "Controls",
      "lines": [
        "Jog: navigate menu",
        "Jog click: edit value",
        "Pads: toggle playback",
        "Back: exit tool",
        "",
        "Menu items:",
        " Bars: song length",
        "   (1/4 to 16 bars)",
        " Target BPM: desired",
        "   tempo (40-300)",
        " Pitch: transpose",
        "   (-12 to +12 st)",
        " Save: export result"
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "Two save modes:",
        "",
        "Overwrite: replaces",
        " the original file",
        "",
        "New File: browse to",
        " a destination folder",
        " and save with BPM",
        " in the filename",
        " (e.g. loop-120bpm)",
        "",
        "Pitch is included in",
        "the filename when",
        "non-zero (e.g.",
        " loop-120bpm+3st)"
      ]
    },
    {
      "title": "Tips",
      "lines": [
        "Set Bars first, then",
        "adjust Target BPM.",
        "",
        "Source BPM is shown",
        "at the top alongside",
        "the speed multiplier.",
        "",
        "Use Pitch to shift",
        "up or down by up to",
        "one octave without",
        "changing the tempo.",
        "",
        "Press any pad to",
        "preview in real time",
        "before saving."
      ]
    }
  ]
}
